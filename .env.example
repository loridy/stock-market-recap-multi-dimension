# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.

# Required for Stage 5 (LLM synthesis)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Cost control (optional)
# If omitted, pipeline defaults to claude-sonnet-4-6.
# You can set a cheaper model here if your Anthropic account supports it.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=650

# Optional for Stage 1b (newsfilter secondary source)
# Leave empty to keep RSS-only mode.
NEWSFILTER_API_KEY=
