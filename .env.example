# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.

# Stage 5 LLM provider (gemini|claude). Default is gemini.
LLM_PROVIDER=gemini

# Gemini (recommended)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=700
GEMINI_TEMPERATURE=0.2

# Claude (optional fallback)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=650

# Optional for Stage 1b (newsfilter secondary source)
# Leave empty to keep RSS-only mode.
NEWSFILTER_API_KEY=
