{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Market Recap Report",
  "type": "object",
  "required": ["date", "project", "executive_summary", "current_regime", "sections", "analyst_views", "next_actions"],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "project": { "type": "string" },
    "current_regime": { "type": "string" },
    "executive_summary": { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 7 },
    "sections": {
      "type": "object",
      "properties": {
        "market_state": { "$ref": "#/definitions/market_state" },
        "sector_rotation": { "$ref": "#/definitions/sector_rotation" },
        "flow_positioning": { "$ref": "#/definitions/flow_positioning" },
        "macro_drivers": { "$ref": "#/definitions/macro_drivers" },
        "signal_factor": { "$ref": "#/definitions/signal_factor" }
      }
    },
    "market_heatmap": {
      "type": "object",
      "properties": {
        "indices": { "type": "array", "items": { "$ref": "#/definitions/heatmap_item" } },
        "commodities": { "type": "array", "items": { "$ref": "#/definitions/heatmap_item" } },
        "yields": { "type": "array", "items": { "$ref": "#/definitions/heatmap_item" } },
        "fx": { "type": "array", "items": { "$ref": "#/definitions/heatmap_item" } }
      }
    },
    "breaking_news": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "source", "url"],
        "properties": {
          "title": { "type": "string" },
          "source": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "published_at": { "type": "string" }
        }
      }
    },
    "analyst_focus": {
      "type": "object",
      "properties": {
        "mark": { "$ref": "#/definitions/focus_item" },
        "alex": { "$ref": "#/definitions/focus_item" },
        "loridy": { "$ref": "#/definitions/focus_item" },
        "freya": { "$ref": "#/definitions/focus_item" }
      }
    },
    "analyst_views": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["analyst", "focus", "highlights", "risks", "actions"],
        "properties": {
          "analyst": { "type": "string" },
          "focus": { "type": "string" },
          "highlights": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } },
          "actions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "next_actions": { "type": "array", "items": { "type": "string" } }
  },
  "definitions": {
    "market_state": { "type": "object" },
    "sector_rotation": { "type": "object" },
    "flow_positioning": { "type": "object" },
    "macro_drivers": { "type": "object" },
    "signal_factor": { "type": "object" },
    "heatmap_item": {
      "type": "object",
      "required": ["name", "current", "d1", "d1Pct", "d5Pct", "m1Pct", "ytdPct", "y1Pct"],
      "properties": {
        "name": { "type": "string" },
        "ticker": { "type": "string" },
        "current": { "type": "number" },
        "d1": { "type": "number" },
        "d1Pct": { "type": "number" },
        "d5Pct": { "type": "number" },
        "m1Pct": { "type": "number" },
        "ytdPct": { "type": "number" },
        "y1Pct": { "type": "number" }
      }
    },
    "focus_item": {
      "type": "object",
      "required": ["title", "subtitle", "bullets"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "bullets": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
